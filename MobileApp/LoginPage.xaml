<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileApp.LoginPage"
             Title="Login">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="Login" FontSize="24" HorizontalOptions="Center" />

        <Entry x:Name="txtEmail" Placeholder="Email" Keyboard="Email" />
        <Entry x:Name="txtPassword" Placeholder="Password" IsPassword="True" />

        <Button Text="Login" Clicked="Login_Clicked" BackgroundColor="#6A5ACD" TextColor="White"/>

        <Label Text="Don't have an account?" HorizontalOptions="Center" />
        <Button Text="Register" Clicked="GoToRegister" BackgroundColor="Transparent" TextColor="Blue"/>

    </VerticalStackLayout>
</ContentPage>
