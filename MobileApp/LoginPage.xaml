<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileApp.LoginPage"
             Title="Login">
    <StackLayout Padding="20" Spacing="10">
        <Image Source="logo.png" HeightRequest="100" WidthRequest="100" />
        <Label Text="Login" FontSize="20" />
        <Entry Placeholder="Email" x:Name="EmailEntry" />
        <Entry Placeholder="Password" x:Name="PasswordEntry" IsPassword="True" />
        <Button Text="Login" Clicked="OnLoginButtonClicked" />
    </StackLayout>
</ContentPage>