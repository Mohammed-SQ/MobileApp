<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileApp.RegisterPage"
             Title="Register">
    <VerticalStackLayout Padding="20" Spacing="20">
        <Entry x:Name="txtUsername" Placeholder="Username"/>
        <Entry x:Name="txtEmail" Placeholder="Email" Keyboard="Email"/>
        <Entry x:Name="txtPassword" Placeholder="Password" IsPassword="True"/>
        <Button Text="Register" Clicked="Register_Clicked"/>
    </VerticalStackLayout>
</ContentPage>
